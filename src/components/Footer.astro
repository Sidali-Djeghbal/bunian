---
import { socialIcons, type SocialIconKey } from "../data/social-icons";

const today = new Date();

const socialLinks: Array<{ name: string; icon: SocialIconKey; url: string; color: string }> = [
  {
    name: "فيسبوك",
    icon: "fb",
    url: "https://www.facebook.com/BunianFoundation",
    color: "hover:bg-blue-500/10 hover:border-blue-500/30 hover:text-blue-400",
  },
  {
    name: "إنستغرام",
    icon: "ig",
    url: "https://www.instagram.com/bunian.ar?igsh=MWxsM2sydzFqbWEyYg==",
    color: "hover:bg-pink-500/10 hover:border-pink-500/30 hover:text-pink-400",
  },
  {
    name: "تليجرام",
    icon: "tg",
    url: "https://t.me/Algerianspositivevibes",
    color: "hover:bg-sky-500/10 hover:border-sky-500/30 hover:text-sky-400",
  },
  {
    name: "يوتيوب",
    icon: "yt",
    url: "https://youtube.com/channel/UCIfXPqovW2lulgVg49qh4Rw",
    color: "hover:bg-red-500/10 hover:border-red-500/30 hover:text-red-400",
  },
  {
    name: "لينكد إن",
    icon: "ln",
    url: "https://www.linkedin.com/company/bunian-%D8%A8%D9%86%D9%8A%D8%A7%D9%86/",
    color: "hover:bg-blue-600/10 hover:border-blue-600/30 hover:text-blue-500",
  },
  {
    name: "ساوندكلاود",
    icon: "soundcloud",
    url: "https://soundcloud.com/user-677669497-573369962",
    color: "hover:bg-orange-500/10 hover:border-orange-500/30 hover:text-orange-400",
  },
];
---

<footer class="relative px-4 pt-6 pb-10 text-center">

  <div class="mt-4 flex items-center justify-center gap-4 flex-wrap">
    {socialLinks.map((link) => (
      <a
        href={link.url}
        target="_blank"
        rel="noreferrer"
        aria-label={link.name}
        class={`group inline-flex h-12 w-12 items-center justify-center rounded-full border border-white/10 bg-white/[0.03] backdrop-blur-sm transition-all duration-300 hover:scale-110 hover:opacity-100 ${link.color}`}
      >
        <span class="h-[24px] w-[24px] transition-transform duration-300 group-hover:scale-110" set:html={socialIcons[link.icon]} />
      </a>
    ))}
  </div>

  <p class="mt-8 text-sm">
    &copy; {today.getFullYear()} بنيان. جميع الحقوق محفوظة.
  </p>

</footer>
